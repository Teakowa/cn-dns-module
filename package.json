{
  "name": "cn-dns-module",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Generate Egern rule sets and frozen Surge modules from dnsmasq domain lists",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "gen": "node dist/index.js --mode egern",
    "generate:all": "node dist/index.js --generate-all --modules-dir modules --repo Teakowa/cn-dns-module"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3"
  }
}
